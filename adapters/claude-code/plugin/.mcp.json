{
  "tavily": {
    "command": "npx",
    "args": ["-y", "tavily-mcp"],
    "env": { "TAVILY_API_KEY": "${TAVILY_API_KEY}" }
  },
  "exa": {
    "type": "http",
    "url": "https://mcp.exa.ai/mcp",
    "headers": { "Authorization": "Bearer ${EXA_API_KEY}" }
  },
  "context7": {
    "type": "http",
    "url": "https://mcp.context7.com/mcp"
  }
}
